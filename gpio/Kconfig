menu "Motor GPIO Configuration"

    config LEFT_MOTOR_FORWARD
        int "Left motor forward"
        default 32

    config LEFT_MOTOR_REVERSE
        int "Left motor reverse"
        default 30

    config LEFT_MOTOR_PWM
        int "Left motor PWM speed pin"
        default 28


    config RIGHT_MOTOR
        int "Right motor direction pin"
        default 13


    config RIGHT_MOTOR_PWM
        int "Right motor PWM speed pin"
        default 27


endmenu